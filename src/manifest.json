{
  "manifest_version": 3,
  "name": "YT Dual Sub",
  "version": "0.1.0",
  "description": "Custom YouTube dual subtitles with translated second subtitle.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.googlevideo.com/*"
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "YT Dual Sub"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content-loader.js"],
      "css": ["assets/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js", "content.js", "assets/*.js", "assets/*.js.map"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}